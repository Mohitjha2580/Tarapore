{
  "name": "school-engagement-backend",
  "version": "1.0.0",
  "description": "Scalable backend API for gamified school engagement platform",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "migrate": "prisma migrate dev",
    "generate": "prisma generate",
    "seed": "tsx src/database/seed.ts",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "docs": "swagger-jsdoc -d swaggerDef.js src/routes/*.ts -o swagger.json"
  },
  "dependencies": {
    "@prisma/client": "^5.6.0",
    "@types/node": "^20.8.0",
    "express": "^4.18.2",
    "helmet": "^7.1.0",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "socket.io": "^4.7.2",
    "redis": "^4.6.8",
    "multer": "^1.4.5-lts.1",
    "@aws-sdk/client-s3": "^3.441.0",
    "@sendgrid/mail": "^7.7.0",
    "zod": "^3.22.4",
    "winston": "^3.11.0",
    "express-rate-limit": "^7.1.3",
    "compression": "^1.7.4",
    "express-validator": "^7.0.1",
    "node-cron": "^3.0.2",
    "uuid": "^9.0.1",
    "dotenv": "^16.3.1",
    "express-async-errors": "^3.1.1"
  },
  "devDependencies": {
    "@types/express": "^4.17.20",
    "@types/bcryptjs": "^2.4.4",
    "@types/jsonwebtoken": "^9.0.3",
    "@types/multer": "^1.4.8",
    "@types/cors": "^2.8.14",
    "@types/compression": "^1.7.4",
    "@types/uuid": "^9.0.5",
    "@types/node-cron": "^3.0.8",
    "@types/jest": "^29.5.6",
    "@types/supertest": "^2.0.14",
    "typescript": "^5.2.2",
    "tsx": "^3.14.0",
    "jest": "^29.7.0",
    "supertest": "^6.3.3",
    "prisma": "^5.6.0",
    "eslint": "^8.51.0",
    "@typescript-eslint/eslint-plugin": "^6.7.4",
    "@typescript-eslint/parser": "^6.7.4",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.0"
  },
  "keywords": [
    "school",
    "engagement",
    "gamification",
    "education",
    "nodejs",
    "typescript",
    "express",
    "postgresql"
  ],
  "author": "School Engagement Team",
  "license": "MIT"
}